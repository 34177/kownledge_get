{
  "_comment": "API 技术文档采集源配置",
  "_updated": "2026-03-17",
  
  "git": [
    {
      "name": "React 官方文档",
      "url": "https://github.com/facebook/react.git",
      "branch": "main",
      "paths": ["packages/react.dev/content"],
      "output": "react-docs.md",
      "enabled": true
    },
    {
      "name": "TypeScript 手册",
      "url": "https://github.com/microsoft/TypeScript-Website.git",
      "branch": "v2",
      "paths": ["packages/typescriptlang-org/src/content"],
      "output": "typescript-handbook.md",
      "enabled": true
    },
    {
      "name": "Vue.js 文档",
      "url": "https://github.com/vuejs/docs.git",
      "branch": "main",
      "paths": ["src"],
      "output": "vue-docs.md",
      "enabled": true
    },
    {
      "name": "Rust 参考",
      "url": "https://github.com/rust-lang/reference.git",
      "branch": "master",
      "paths": ["src"],
      "output": "rust-reference.md",
      "enabled": true
    }
  ],
  
  "browser": [
    {
      "name": "MDN Web Docs - JavaScript",
      "url": "https://developer.mozilla.org/en-US/docs/Web/JavaScript",
      "selector": "article",
      "output": "mdn-javascript.md",
      "enabled": true,
      "refresh": "weekly"
    },
    {
      "name": "MDN Web Docs - API 参考",
      "url": "https://developer.mozilla.org/en-US/docs/Web/API",
      "selector": "article",
      "output": "mdn-api.md",
      "enabled": true,
      "refresh": "weekly"
    },
    {
      "name": "OpenAI API 文档",
      "url": "https://platform.openai.com/docs",
      "selector": "main",
      "output": "openai-api.md",
      "enabled": true,
      "refresh": "daily"
    },
    {
      "name": "Anthropic API 文档",
      "url": "https://docs.anthropic.com/claude/docs",
      "selector": "main",
      "output": "anthropic-api.md",
      "enabled": true,
      "refresh": "daily"
    },
    {
      "name": "Hugging Face Docs",
      "url": "https://huggingface.co/docs",
      "selector": "main",
      "output": "huggingface-docs.md",
      "enabled": true,
      "refresh": "weekly"
    }
  ],
  
  "api": [
    {
      "name": "GitHub API - Releases",
      "endpoint": "https://api.github.com/repos/facebook/react/releases",
      "auth": false,
      "output": "github-releases.json",
      "enabled": true
    },
    {
      "name": "Hugging Face Blog",
      "endpoint": "https://huggingface.co/api/posts",
      "auth": false,
      "output": "hf-blog.json",
      "enabled": true
    }
  ]
}
