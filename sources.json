{
  "_comment": "API 技术文档采集源配置",
  "_updated": "2026-03-18",
  
  "git": [
    {
      "name": "React 官方文档",
      "url": "https://github.com/reactjs/react.dev.git",
      "description": "React 官方文档仓库",
      "enabled": true,
      "branch": "main",
      "paths": ["src/content/docs"],
      "output": "react-docs.md"
    },
    {
      "name": "TypeScript Handbook",
      "url": "https://github.com/microsoft/TypeScript-Website.git",
      "description": "TypeScript 官方手册",
      "enabled": true,
      "branch": "v2",
      "paths": ["packages/typescriptlang-org/src/copy"],
      "output": "typescript-handbook.md"
    }
  ],
  
  "browser": [
    {
      "name": "MDN JavaScript",
      "url": "https://developer.mozilla.org/zh-CN/docs/Web/JavaScript",
      "description": "MDN JavaScript 参考",
      "enabled": true,
      "selector": "article",
      "output": "mdn-javascript.md"
    },
    {
      "name": "OpenAI API Docs",
      "url": "https://platform.openai.com/docs",
      "description": "OpenAI API 文档",
      "enabled": true,
      "selector": "main",
      "output": "openai-api.md"
    },
    {
      "name": "Anthropic API Docs",
      "url": "https://docs.anthropic.com",
      "description": "Anthropic API 文档",
      "enabled": true,
      "selector": "body",
      "output": "anthropic-api.md"
    }
  ],
  
  "api": [
    {
      "name": "Hugging Face Blog",
      "endpoint": "https://huggingface.co/api/blog",
      "description": "HF 博客文章列表",
      "enabled": true,
      "output": "hf-blog.json",
      "auth": false
    }
  ],
  
  "categories": [
    "algorithms",
    "programming",
    "ai-ml",
    "software-engineering",
    "database",
    "network",
    "system",
    "security"
  ]
}
